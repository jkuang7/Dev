{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/minimax-m2.5-free",
  "mcp": {
		"chrome-devtools": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"chrome-devtools-mcp@latest",
				"--browser-url=http://127.0.0.1:9222"
			],
			"enabled": true
		},
		"playwright": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@playwright/mcp",
				"--caps",
				"vision,pdf",
				"--browser",
				"chrome",
				"--user-data-dir",
				"/Users/jian/.codex/playwright-chrome-profile"
			],
			"enabled": true
		},
		"react-native-debugger": {
			"type": "local",
			"command": ["npx", "-y", "@twodoorsdev/react-native-debugger-mcp"],
			"enabled": true
		},
		"context7": {
			"type": "local",
			"command": [
				"npx",
				"-y",
				"@upstash/context7-mcp",
				"--api-key",
				"ctx7sk-6ef84834-b17e-4a2e-ae71-2f1175f2bae4"
			],
			"enabled": true
		}
  },
  "skills": {
    "paths": [
      "/Users/jian/.codex/skills"
    ]
  },
  "plugin": [
    "opencode-agent-memory"
  ]
}
