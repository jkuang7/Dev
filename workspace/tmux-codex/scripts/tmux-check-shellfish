#!/bin/bash
# Detect if a tmux client is Shellfish by checking its shell's LC_TERMINAL.
# Scrollability priority: keep mouse enabled for all clients.

tty="$1"
[[ -z "$tty" ]] && exit 1

# Find shell process on this TTY
pid=$(ps -t "${tty#/dev/}" -o pid=,comm= 2>/dev/null | grep -E 'zsh|bash' | head -1 | awk '{print $1}')

if [[ -n "$pid" ]]; then
  # Check LC_TERMINAL in process environment
  if ps -Eww -p "$pid" 2>/dev/null | grep -q 'LC_TERMINAL=ShellFish'; then
    tmux set -g mouse on
    exit 0
  fi
fi

tmux set -g mouse on
