#!/usr/bin/env python3
"""Codex Session Manager - tmux-based Codex session management.

Usage:
    cl                              Interactive session menu
    cl ls                           List/attach sessions
    cl loop <project>               Start Codex infinite loop runner
    cl loop <project> --complexity high
    cl loop <project> --complexity xhigh
    cl loop <project> --runner-id alpha
    cl stop <project>               Stop Codex infinite loop runner
    cl k <project>                  Alias for stop
    cl ka <project>                 Alias for stop
    cl kb <project>                 Alias for stop
    cl k*                           Stop all infinite loop runners
    cl --help                       Show this help
"""

import os
import sys
from pathlib import Path

script_dir = Path(__file__).resolve().parent
repo_root = script_dir.parent
src_root = repo_root
sys.path.insert(0, str(src_root))

# Ensure tmux config hooks can resolve script paths.
os.environ.setdefault("TMUX_CLI_HOME", str(repo_root))

from src.main import main


if __name__ == "__main__":
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__)
        sys.exit(0)
    main()
